# =============================================================================
#  USAGE — copy this file to  .env   (use .env, NOT .env.local)
# -----------------------------------------------------------------------------
#    cp .env.example .env        # then fill in the values below
#
#  • .env is the convention for this Python project. (.env.local is a Node/
#    Next.js idiom — nothing here uses it.) Both are gitignored, so your real
#    key is never committed: .gitignore ignores `.env` and `.env.*` but keeps
#    `.env.example`.
#  • This app reads real process environment variables and does NOT auto-load
#    .env (no python-dotenv dependency). Load it into your shell first:
#        set -a && source .env && set +a
#    …or export the vars directly:
#        export DASHSCOPE_API_KEY=sk-...
#  • Everything runs offline with ZERO keys by default; the values below are
#    only needed for the live Qwen Cloud path.
# =============================================================================

# Permafrost runs entirely offline/keyless by default (FakeQwen transport,
# tests, replay, and bench all pass with NO environment variables set).
# These are only needed to exercise the live Qwen Cloud path.

# ── Qwen Cloud (DashScope, OpenAI-compatible endpoint) ──────────
# Get from: https://dashscope.console.aliyun.com/apiKey (international: dashscope-intl.aliyuncs.com)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# Set to 1 to route /diagnose, /distill, and the TTS alert through LiveQwen
# instead of the deterministic FakeQwen fixture transport.
PERMAFROST_LIVE=0

# ── Edge signing / sealing keys (production deployments only) ───
# Dev/demo keys are deterministically derived in code (tests/replay never
# need these). For a real deployment, generate your own and keep them OUT
# of the repo:
#   python -c "from permafrost.crypto import generate_signing_seed as g; print(g())"
#   python -c "from permafrost.crypto import generate_sealing_private as g; print(g())"
# PERMAFROST_SIGNING_SEED=your-ed25519-signing-seed-here
# PERMAFROST_SEALING_PRIVATE=your-x25519-sealing-private-key-here
